# Blog Agent Configuration

# MiniMax API (default)
minimax:
  api_key: ""
  base_url: "https://api.minimaxi.com/v1"

# OpenAI API (optional)
openai:
  api_key: ""
  base_url: "https://api-2.xi-ai.cn/v1"

# Google Gemini API (optional)
gemini:
  api_key: ""
  base_url: "https://api.xi-ai.cn/v1"

# GenGraph (image generation for figures)
gengraph:
  provider: "xiai"  # Select your preferred provider
  api_key: ""
  providers:  # Default configuration for each provider, can be customized
    xiai:
      base_url: "https://api.xi-ai.cn/v1"
      model: "gemini-3-pro-image-preview"
    openrouter:
      base_url: "https://openrouter.ai/api/v1"
      model: "google/gemini-3-pro-image-preview"
    bianxie:
      base_url: "https://api.bianxie.ai/v1"
      model: "gemini-3-pro-image-preview"
    gemini:
      base_url: "https://generativelanguage.googleapis.com/v1beta"
      model: "gemini-3-pro-image-preview"


# DeepEraser (text removal)
deeperaser:
  use_cuda: false  # Whether to use GPU

# Semantic Scholar API (for paper abstract retrieval and PDF download)
semantic_scholar:
  api_key: ""  # Optional: your Semantic Scholar API key

# Default Model settings (It is only used when you do not pass the model parameter when creating an agent.)
model: "MiniMax-M2.5"

# Blog Illustrate settings
illustrate:
  only_gen_img: true  # true: only generate images, no OCR; false: generate + OCR cleanup

