{
    "schema_proposal": {
        "title": {
            "data_type": "string",
            "description": "Paper title",
            "rationale": "Canonical identifier for the paper."
        },
        "authors": {
            "data_type": "list",
            "description": "List of authors",
            "rationale": "Credit and disambiguation of contributions."
        },
        "year": {
            "data_type": "integer",
            "description": "Publication year",
            "rationale": "Contextualizes the research within its timeline."
        },
        "abstract": {
            "data_type": "string",
            "description": "Abstract of the paper",
            "rationale": "Provides a concise summary of the study."
        },
        "doi": {
            "data_type": "string",
            "description": "Digital Object Identifier",
            "rationale": "Unique identifier for accessing the paper online."
        },
        "venue": {
            "data_type": "string",
            "description": "Publication venue",
            "rationale": "Indicates the platform where the research is published."
        },
        "problem_statement": {
            "data_type": "object",
            "description": "Description of the problem addressed",
            "rationale": "Clarifies the specific issues the research aims to solve.",
            "sub_keys": {
                "description": {
                    "data_type": "string",
                    "description": "Detailed explanation of the problem",
                    "rationale": "Sets the foundation for understanding the research."
                },
                "challenges": {
                    "data_type": "list",
                    "description": "List of challenges related to the problem",
                    "rationale": "Highlights obstacles that need to be overcome."
                }
            }
        },
        "methodology": {
            "data_type": "object",
            "description": "Methods used in the research",
            "rationale": "Describes the approach taken to address the problem.",
            "sub_keys": {
                "framework": {
                    "data_type": "string",
                    "description": "Research framework or model used",
                    "rationale": "Provides insight into the structure of the research."
                },
                "algorithms": {
                    "data_type": "list",
                    "description": "List of algorithms utilized",
                    "rationale": "Details the computational techniques applied."
                },
                "data_collection": {
                    "data_type": "object",
                    "description": "Details on data collection methods",
                    "rationale": "Explains how data was gathered for analysis.",
                    "sub_keys": {
                        "sources": {
                            "data_type": "list",
                            "description": "Sources of data used",
                            "rationale": "Identifies where the data was obtained from."
                        },
                        "techniques": {
                            "data_type": "list",
                            "description": "Techniques for data collection",
                            "rationale": "Describes the methods used to gather data."
                        }
                    }
                }
            }
        },
        "experiments": {
            "data_type": "object",
            "description": "Overview of experiments conducted",
            "rationale": "Details the empirical work to validate the methods.",
            "sub_keys": {
                "setup": {
                    "data_type": "string",
                    "description": "Experimental setup description",
                    "rationale": "Describes how the experiments were structured."
                },
                "evaluation_metrics": {
                    "data_type": "list",
                    "description": "Metrics used for evaluation",
                    "rationale": "Defines how the results were measured."
                },
                "results": {
                    "data_type": "object",
                    "description": "Summary of results obtained",
                    "rationale": "Presents the outcomes of the experiments.",
                    "sub_keys": {
                        "findings": {
                            "data_type": "string",
                            "description": "Key findings from the results",
                            "rationale": "Highlights the most important discoveries."
                        },
                        "comparisons": {
                            "data_type": "list",
                            "description": "Comparisons with baseline or previous work",
                            "rationale": "Contextualizes results against existing research."
                        }
                    }
                }
            }
        },
        "discussion": {
            "data_type": "object",
            "description": "Discussion of implications and insights",
            "rationale": "Explores the significance of the findings.",
            "sub_keys": {
                "implications": {
                    "data_type": "string",
                    "description": "Implications of the research findings",
                    "rationale": "Discusses the broader impact of the results."
                },
                "future_work": {
                    "data_type": "list",
                    "description": "Suggestions for future research",
                    "rationale": "Identifies areas for further investigation."
                }
            }
        },
        "reproducibility_metadata": {
            "data_type": "object",
            "description": "Information on reproducibility",
            "rationale": "Ensures that the research can be replicated.",
            "sub_keys": {
                "code_availability": {
                    "data_type": "boolean",
                    "description": "Is the code available for public access?",
                    "rationale": "Indicates if the implementation can be reused."
                },
                "data_availability": {
                    "data_type": "boolean",
                    "description": "Is the dataset available for public use?",
                    "rationale": "Shows if the data used can be accessed by others."
                },
                "license": {
                    "data_type": "string",
                    "description": "License type for the code and data",
                    "rationale": "Specifies the terms under which the code/data can be used."
                }
            }
        }
    }
}