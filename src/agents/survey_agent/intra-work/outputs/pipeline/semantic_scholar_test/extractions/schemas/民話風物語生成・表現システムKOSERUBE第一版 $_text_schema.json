{
    "schema_proposal": {
        "title": {
            "data_type": "string",
            "description": "Paper title",
            "rationale": "Canonical identifier."
        },
        "authors": {
            "data_type": "list",
            "description": "List of authors",
            "rationale": "Credit and disambiguation."
        },
        "year": {
            "data_type": "integer",
            "description": "Publication year",
            "rationale": "Contextualizes the research within time."
        },
        "abstract": {
            "data_type": "string",
            "description": "Summary of the paper",
            "rationale": "Provides a concise overview of the research."
        },
        "doi": {
            "data_type": "string",
            "description": "Digital Object Identifier",
            "rationale": "Unique identifier for accessing the paper."
        },
        "venue": {
            "data_type": "string",
            "description": "Publication venue (journal or conference)",
            "rationale": "Indicates where the research was presented."
        },
        "keywords": {
            "data_type": "list",
            "description": "Keywords associated with the paper",
            "rationale": "Facilitates searching and indexing the research."
        },
        "system_overview": {
            "data_type": "object",
            "description": "Overview of the KOSERUBE system",
            "rationale": "Describes the main functionalities and design of the system.",
            "sub_keys": {
                "narrative_generation_mechanism": {
                    "data_type": "string",
                    "description": "Mechanism for generating narratives",
                    "rationale": "Explains the core technology used."
                },
                "user_interface": {
                    "data_type": "string",
                    "description": "Description of the user interface",
                    "rationale": "Details how users interact with the system."
                }
            }
        },
        "results": {
            "data_type": "object",
            "description": "Results of the experiments conducted",
            "rationale": "Summarizes findings to evaluate the system's performance.",
            "sub_keys": {
                "questionnaire_results": {
                    "data_type": "object",
                    "description": "Results from user questionnaires",
                    "rationale": "Provides insights into user satisfaction and areas for improvement.",
                    "sub_keys": {
                        "positive_feedback": {
                            "data_type": "list",
                            "description": "List of positive feedback points",
                            "rationale": "Highlights strengths of the system."
                        },
                        "negative_feedback": {
                            "data_type": "list",
                            "description": "List of negative feedback points",
                            "rationale": "Identifies weaknesses and areas for enhancement."
                        }
                    }
                },
                "demonstration_results": {
                    "data_type": "string",
                    "description": "Summary of results from demonstrations",
                    "rationale": "Describes audience reactions and engagement during demonstrations."
                }
            }
        },
        "discussion": {
            "data_type": "object",
            "description": "Discussion of findings and future directions",
            "rationale": "Analyzes results and proposes future work.",
            "sub_keys": {
                "identified_issues": {
                    "data_type": "list",
                    "description": "List of issues identified during the study",
                    "rationale": "Helps in understanding challenges faced in narrative generation."
                },
                "future_research_directions": {
                    "data_type": "list",
                    "description": "Proposed directions for future research",
                    "rationale": "Guides subsequent studies and improvements."
                }
            }
        }
    }
}