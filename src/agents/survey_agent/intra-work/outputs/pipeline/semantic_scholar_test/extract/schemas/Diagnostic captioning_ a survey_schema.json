{
    "schema_proposal": {
        "title": {
            "data_type": "string",
            "description": "Paper title",
            "rationale": "Canonical identifier for the paper."
        },
        "authors": {
            "data_type": "list",
            "description": "List of authors",
            "rationale": "Credit and disambiguation of contributions."
        },
        "year": {
            "data_type": "integer",
            "description": "Year of publication",
            "rationale": "Contextualizes the research within the field."
        },
        "abstract": {
            "data_type": "string",
            "description": "Summary of the paper",
            "rationale": "Provides a concise overview of the research."
        },
        "doi": {
            "data_type": "string",
            "description": "Digital Object Identifier",
            "rationale": "Unique identifier for accessing the paper online."
        },
        "venue": {
            "data_type": "string",
            "description": "Publication venue (journal/conference)",
            "rationale": "Indicates the platform where the research is published."
        },
        "problem_statement": {
            "data_type": "string",
            "description": "Description of the problem addressed",
            "rationale": "Clarifies the research focus and significance."
        },
        "methodology": {
            "data_type": "object",
            "description": "Overview of the methods used",
            "rationale": "Details the approach taken to solve the problem.",
            "sub_keys": {
                "method_type": {
                    "data_type": "string",
                    "description": "Type of method (e.g., deep learning, retrieval-based)",
                    "rationale": "Categorizes the methodological approach."
                },
                "architecture": {
                    "data_type": "string",
                    "description": "Description of the architecture used",
                    "rationale": "Provides insight into the technical implementation."
                },
                "data_sources": {
                    "data_type": "list",
                    "description": "Datasets used in the research",
                    "rationale": "Identifies the data that informs the research."
                }
            }
        },
        "experiments": {
            "data_type": "object",
            "description": "Details of the experiments conducted",
            "rationale": "Describes how the methods were evaluated.",
            "sub_keys": {
                "experiment_design": {
                    "data_type": "string",
                    "description": "Design of the experiments",
                    "rationale": "Explains the structure and rationale of experiments."
                },
                "evaluation_metrics": {
                    "data_type": "list",
                    "description": "Metrics used for evaluation",
                    "rationale": "Defines how the results were measured."
                }
            }
        },
        "results": {
            "data_type": "object",
            "description": "Summary of the results obtained",
            "rationale": "Presents findings that validate the research.",
            "sub_keys": {
                "key_findings": {
                    "data_type": "string",
                    "description": "Main findings of the research",
                    "rationale": "Highlights the most significant outcomes."
                },
                "statistical_significance": {
                    "data_type": "boolean",
                    "description": "Indicates if results are statistically significant",
                    "rationale": "Shows the reliability of the findings."
                }
            }
        },
        "discussion": {
            "data_type": "object",
            "description": "Interpretation of results and implications",
            "rationale": "Explores the broader impact of the findings.",
            "sub_keys": {
                "advantages": {
                    "data_type": "list",
                    "description": "Advantages of the proposed method",
                    "rationale": "Enumerates benefits over existing approaches."
                },
                "limitations": {
                    "data_type": "list",
                    "description": "Limitations encountered in the study",
                    "rationale": "Acknowledges areas for improvement."
                },
                "future_work": {
                    "data_type": "list",
                    "description": "Suggested future research directions",
                    "rationale": "Guides subsequent investigations in the field."
                }
            }
        },
        "reproducibility_metadata": {
            "data_type": "object",
            "description": "Information for reproducing the study",
            "rationale": "Ensures transparency and replicability.",
            "sub_keys": {
                "code_availability": {
                    "data_type": "string",
                    "description": "Link to the code repository",
                    "rationale": "Facilitates access to the implementation."
                },
                "dataset_availability": {
                    "data_type": "string",
                    "description": "Link to the datasets used",
                    "rationale": "Enables access to the data for validation."
                },
                "environment": {
                    "data_type": "string",
                    "description": "Description of the computational environment",
                    "rationale": "Specifies the setup required for replication."
                }
            }
        }
    }
}