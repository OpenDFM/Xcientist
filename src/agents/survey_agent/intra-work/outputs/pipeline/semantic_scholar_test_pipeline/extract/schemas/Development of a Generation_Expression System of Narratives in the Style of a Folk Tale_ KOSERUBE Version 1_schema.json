{
    "schema_proposal": {
        "title": {
            "data_type": "string",
            "description": "Paper title",
            "rationale": "Canonical identifier for the research."
        },
        "authors": {
            "data_type": "list",
            "description": "List of authors",
            "rationale": "Credit and disambiguation of contributions."
        },
        "year": {
            "data_type": "integer",
            "description": "Year of publication",
            "rationale": "Establishes the timeline of the research."
        },
        "abstract": {
            "data_type": "string",
            "description": "Summary of the paper",
            "rationale": "Provides a concise overview of the research."
        },
        "doi": {
            "data_type": "string",
            "description": "Digital Object Identifier",
            "rationale": "Permanent identifier for accessing the paper."
        },
        "venue": {
            "data_type": "string",
            "description": "Publication venue",
            "rationale": "Indicates where the research was published."
        },
        "keywords": {
            "data_type": "list",
            "description": "List of keywords",
            "rationale": "Facilitates indexing and searchability of the paper."
        },
        "narrative_generation_system": {
            "data_type": "object",
            "description": "Details of the narrative generation system",
            "rationale": "Describes the core system functionalities and mechanisms.",
            "sub_keys": {
                "system_name": {
                    "data_type": "string",
                    "description": "Name of the system",
                    "rationale": "Identifies the system being discussed."
                },
                "generation_mechanism": {
                    "data_type": "object",
                    "description": "Mechanism used for narrative generation",
                    "rationale": "Explains the foundational approach for generating narratives.",
                    "sub_keys": {
                        "grammar_type": {
                            "data_type": "string",
                            "description": "Type of story grammar used",
                            "rationale": "Specifies the theoretical framework guiding the generation."
                        },
                        "components": {
                            "data_type": "list",
                            "description": "Components involved in generation",
                            "rationale": "Lists the elements that contribute to the narrative generation process."
                        }
                    }
                },
                "user_interface": {
                    "data_type": "object",
                    "description": "Description of the user interface",
                    "rationale": "Describes how users interact with the system.",
                    "sub_keys": {
                        "interface_design": {
                            "data_type": "string",
                            "description": "Design features of the interface",
                            "rationale": "Highlights usability and interaction elements."
                        },
                        "user_feedback": {
                            "data_type": "object",
                            "description": "Results from user feedback surveys",
                            "rationale": "Provides insights into user experiences and satisfaction.",
                            "sub_keys": {
                                "positive_responses": {
                                    "data_type": "integer",
                                    "description": "Count of positive feedback",
                                    "rationale": "Quantifies user satisfaction."
                                },
                                "negative_responses": {
                                    "data_type": "integer",
                                    "description": "Count of negative feedback",
                                    "rationale": "Identifies areas for improvement."
                                }
                            }
                        }
                    }
                }
            }
        },
        "evaluation_results": {
            "data_type": "object",
            "description": "Results of the evaluation experiments",
            "rationale": "Summarizes the findings from experiments assessing the system.",
            "sub_keys": {
                "experiment_type": {
                    "data_type": "string",
                    "description": "Type of evaluation conducted",
                    "rationale": "Specifies the nature of the evaluation."
                },
                "findings": {
                    "data_type": "list",
                    "description": "Key findings from the evaluation",
                    "rationale": "Highlights significant results and conclusions drawn from the experiments."
                }
            }
        },
        "future_directions": {
            "data_type": "object",
            "description": "Proposed future work and improvements",
            "rationale": "Outlines next steps for research and development.",
            "sub_keys": {
                "version_two_plans": {
                    "data_type": "string",
                    "description": "Plans for the second version of the system",
                    "rationale": "Details enhancements and new features."
                },
                "challenges_identified": {
                    "data_type": "list",
                    "description": "Challenges encountered during development",
                    "rationale": "Lists obstacles that need to be addressed in future work."
                }
            }
        }
    }
}