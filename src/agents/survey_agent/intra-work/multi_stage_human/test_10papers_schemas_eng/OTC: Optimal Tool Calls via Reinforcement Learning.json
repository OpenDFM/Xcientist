{
  "schema_proposal": {
    "paper_metadata": {
      "data_type": "object",
      "description": "Basic Information of the Paper",
      "rationale": "Record the paper title, authors, and institutional information.",
      "sub_keys": {
        "title": {
          "data_type": "string",
          "description": "Paper Title",
          "rationale": "Identify the paper topic"
        },
        "authors": {
          "data_type": "list",
          "description": "Author List",
          "rationale": "Record paper contributors"
        },
        "affiliations": {
          "data_type": "list",
          "description": "Affiliated Institution",
          "rationale": "Record the author's affiliated institution."
        }
      }
    },
    "problem_background": {
      "data_type": "object",
      "description": "Background and Challenges",
      "rationale": "Understanding research motivations and core issues",
      "sub_keys": {
        "current_issues": {
          "data_type": "string",
          "description": "Existing method issues",
          "rationale": "Document the shortcomings of existing reinforcement learning methods in tool invocation efficiency."
        },
        "target": {
          "data_type": "string",
          "description": "Objective Description",
          "rationale": "Identify the key technologies to be addressed by the research and the objectives to be achieved."
        }
      }
    },
    "contributions": {
      "data_type": "object",
      "description": "Main Contributions",
      "rationale": "Document the core innovations and value of the paper.",
      "sub_keys": {
        "framework_innovation": {
          "data_type": "string",
          "description": "Framework Innovation",
          "rationale": "Innovation at the method extraction level"
        },
        "metric_innovation": {
          "data_type": "string",
          "description": "Indicator Innovation",
          "rationale": "Record newly proposed assessment metrics"
        },
        "algorithm_innovation": {
          "data_type": "string",
          "description": "Algorithm Innovation",
          "rationale": "Innovations in algorithm design extraction"
        },
        "performance_improvement": {
          "data_type": "string",
          "description": "Performance Improvement",
          "rationale": "Actual improvements brought by the recording method"
        }
      }
    },
    "key_findings": {
      "data_type": "object",
      "description": "Key Findings and Conclusions",
      "rationale": "Extract core conclusions from experimental validation",
      "sub_keys": {
        "tool_call_reduction": {
          "data_type": "string",
          "description": "Reduction in tool invocation effects",
          "rationale": "Optimization results for recording tool invocation counts"
        },
        "model_size_effect": {
          "data_type": "string",
          "description": "Impact of Model Scale",
          "rationale": "The impact of model size on method effectiveness"
        },
        "generalization_performance": {
          "data_type": "string",
          "description": "Generalization performance",
          "rationale": "Performance of the recording method on unseen data"
        },
        "case_study_insights": {
          "data_type": "string",
          "description": "Case Study Insights",
          "rationale": "Extracted findings from specific case comparisons"
        }
      }
    },
    "methodology": {
      "data_type": "object",
      "description": "Method Details",
      "rationale": "Document the specific方案 of the technical implementation.",
      "sub_keys": {
        "task_definition": {
          "data_type": "string",
          "description": "Task Definition",
          "rationale": "Extraction of problem formalization description"
        },
        "reward_function": {
          "data_type": "object",
          "description": "Reward Function Design",
          "rationale": "Record reinforcement learning reward mechanism",
          "sub_keys": {
            "base_reward": {
              "data_type": "string",
              "description": "基础奖励",
              "rationale": "记录答案正确性奖励"
            },
            "efficiency_reward": {
              "data_type": "string",
              "description": "效率奖励",
              "rationale": "提取工具使用效率奖励设计"
            },
            "final_reward": {
              "data_type": "string",
              "description": "最终奖励",
              "rationale": "记录奖励组合方式"
            }
          }
        },
        "algorithm_integration": {
          "data_type": "string",
          "description": "Algorithm integration",
          "rationale": "Recording the integration method with PPO/GRPO"
        }
      }
    },
    "experiments": {
      "data_type": "object",
      "description": "Experimental Setup and Results",
      "rationale": "Extraction of experimental configuration and performance evaluation",
      "sub_keys": {
        "experimental_setup": {
          "data_type": "object",
          "description": "Experimental Setup",
          "rationale": "Record experimental environment and parameter configuration.",
          "sub_keys": {
            "datasets": {
              "data_type": "string",
              "description": "数据集信息",
              "rationale": "记录使用的数据集"
            },
            "models": {
              "data_type": "string",
              "description": "模型信息",
              "rationale": "提取使用的模型规格"
            },
            "parameters": {
              "data_type": "string",
              "description": "参数配置",
              "rationale": "记录超参数设置"
            },
            "resources": {
              "data_type": "string",
              "description": "训练资源",
              "rationale": "记录计算资源信息"
            }
          }
        },
        "experimental_results": {
          "data_type": "object",
          "description": "Experimental results",
          "rationale": "Extract quantitative and qualitative assessment results",
          "sub_keys": {
            "search_tool_results": {
              "data_type": "string",
              "description": "搜索工具效果",
              "rationale": "记录搜索任务上的性能"
            },
            "code_tool_results": {
              "data_type": "string",
              "description": "代码工具效果",
              "rationale": "记录代码任务上的性能"
            },
            "behavior_analysis": {
              "data_type": "string",
              "description": "行为分析",
              "rationale": "提取模型行为模式分析"
            }
          }
        }
      }
    }
  }
}