{
  "schema_proposal": {
    "title": {
      "data_type": "string",
      "description": "论文标题",
      "rationale": "标识论文的基本信息"
    },
    "insights": {
      "data_type": "list",
      "description": "研究洞察和发现",
      "rationale": "提取关键研究结论和价值点"
    },
    "article_introduction": {
      "data_type": "object",
      "description": "文章简介部分",
      "rationale": "概述研究背景、贡献和核心思路",
      "sub_keys": {
        "research_background": {
          "data_type": "string",
          "description": "研究背景描述",
          "rationale": "理解研究问题的起源和重要性"
        },
        "main_contributions": {
          "data_type": "string",
          "description": "主要贡献总结",
          "rationale": "识别论文的核心价值和创新点"
        },
        "core_approach": {
          "data_type": "string",
          "description": "核心思路阐述",
          "rationale": "理解方法论的基本框架"
        }
      }
    },
    "methods": {
      "data_type": "object",
      "description": "重点方案详细描述",
      "rationale": "提取具体的技术实现和方法细节",
      "sub_keys": {
        "preparation_stage": {
          "data_type": "object",
          "description": "准备阶段技术方案",
          "rationale": "记录文献检索和预处理方法",
          "sub_keys": {
            "reference_acquisition": {
              "data_type": "string",
              "description": "参考文献获取方法",
              "rationale": "理解数据源和获取策略"
            },
            "retrieval_algorithms": {
              "data_type": "string",
              "description": "检索算法细节",
              "rationale": "提取关键技术实现"
            },
            "reference_preprocessing": {
              "data_type": "string",
              "description": "参考文献预处理方法",
              "rationale": "记录信息提取和结构化技术"
            }
          }
        },
        "generation_stage": {
          "data_type": "object",
          "description": "生成阶段技术方案",
          "rationale": "提取内容生成和优化方法",
          "sub_keys": {
            "outline_generation": {
              "data_type": "string",
              "description": "大纲生成方法",
              "rationale": "记录大纲优化技术"
            },
            "content_generation": {
              "data_type": "string",
              "description": "内容生成方法",
              "rationale": "提取正文生成策略"
            },
            "post_optimization": {
              "data_type": "string",
              "description": "后期优化模块",
              "rationale": "记录重写和图表生成技术"
            }
          }
        }
      }
