{
    "schema_proposal": {
      "code_url": {
        "data_type": "string",
        "description": "源码链接",
        "rationale": "源码内容即为论文的具体实现"
      },
      "dataset_url": {
        "data_type": "string",
        "description": "数据集链接",
        "rationale": "在复现过程中论文数据集是必要的"
      },
      "introduction": {
        "data_type": "object",
        "description": "系统介绍和研究背景",
        "rationale": "理解研究的核心问题和解决方案概述",
        "sub_keys": {
          "problem_statement": {
            "data_type": "string",
            "description": "问题陈述和现有方法不足",
            "rationale": "提取研究要解决的核心问题"
          },
          "proposed_solution": {
            "data_type": "string",
            "description": "提出的解决方案概述",
            "rationale": "记录系统的核心创新点"
          },
          "key_contributions": {
            "data_type": "string",
            "description": "主要贡献总结",
            "rationale": "提取研究的核心价值"
          }
        }
      },
      "motivation": {
        "data_type": "object",
        "description": "研究动机和问题分析",
        "rationale": "理解研究背后的驱动因素",
        "sub_keys": {
          "outline_quality_issues": {
            "data_type": "string",
            "description": "大纲质量问题分析",
            "rationale": "记录现有方法在大纲生成方面的不足"
          },
          "reference_quality_issues": {
            "data_type": "string",
            "description": "参考文献质量问题",
            "rationale": "提取引用准确性方面的问题"
          },
          "evaluation_system_gaps": {
            "data_type": "string",
            "description": "评估体系缺失问题",
            "rationale": "记录评估方法方面的局限性"
          }
        }
      },
      "methods": {
        "data_type": "object",
        "description": "方法框架详细描述",
        "rationale": "提取系统的技术实现细节",
        "sub_keys": {
          "framework_overview": {
            "data_type": "string",
            "description": "框架总体概述",
            "rationale": "记录系统的基本架构"
          },
          "heuristic_outline_generation": {
            "data_type": "object",
            "description": "启发式大纲生成阶段",
            "rationale": "提取第一阶段的技术细节",
            "sub_keys": {
              "knowledge_fusion": {
                "data_type": "string",
                "description": "知识融合过程",
                "rationale": "记录数据检索和整合方法"
              },
              "hierarchical_generation": {
                "data_type": "string",
                "description": "分层生成过程",
                "rationale": "提取大纲生成的具体步骤"
              },
              "memory_construction": {
                "data_type": "string",
                "description": "记忆构建机制",
                "rationale": "记录信息存储和利用方法"
              }
            }
          },
          "memory_driven_content_generation": {
            "data_type": "object",
            "description": "记忆驱动的内容生成阶段",
            "rationale": "提取第二阶段的技术创新",
            "sub_keys": {
              "sana_module": {
                "data_type": "string",
                "description": "SANA模块功能",
                "rationale": "记录智能体的核心能力"
              },
              "query_decomposition": {
                "data_type": "string",
                "description": "子查询分解过程",
                "rationale": "提取查询优化的方法"
              },
              "temporal_aware_reranking": {
                "data_type": "string",
                "description": "时序感知重排引擎",
                "rationale": "记录文献排序的技术"
              },
              "parallel_generation_refinement": {
                "data_type": "string",
                "description": "并行生成与精炼",
                "rationale": "提取内容生成和优化的过程"
              }
            }
          },
          "evaluation_framework": {
            "data_type": "object",
            "description": "评估框架设计",
            "rationale": "记录评估方法和指标体系",
            "sub_keys": {
              "survey_bench": {
                "data_type": "string",
                "description": "SurveyBench基准数据集",
                "rationale": "提取评估数据集的构建"
              },
              "sam_metrics": {
                "data_type": "string",
                "description": "SAM多维度评估指标",
                "rationale": "记录评估指标体系"
              }
            }
          }
        }
      },
      "experimental_results": {
        "data_type": "object",
        "description": "实验结果和分析",
        "rationale": "提取性能评估和对比结果",
        "sub_keys": {
          "outline_quality_comparison": {
            "data_type": "string",
            "description": "大纲质量对比结果",
            "rationale": "记录大纲生成质量的评估"
          },
          "evaluation_win_rate": {
            "data_type": "string",
            "description": "评估胜率对比结果",
            "rationale": "提取自动和人工评估的一致性"
          }
        }
      },
      "conclusions": {
        "data_type": "object",
        "description": "研究结论和意义",
        "rationale": "提取研究的最终总结和应用价值",
        "sub_keys": {
          "technical_contribution": {
            "data_type": "string",
            "description": "技术贡献总结",
            "rationale": "记录方法创新的核心价值"
          },
          "evaluation_contribution": {
            "data_type": "string",
            "description": "评估贡献总结",
            "rationale": "提取评估体系的重要性"
          },
          "application_value": {
            "data_type": "string",
            "description": "应用价值分析",
            "rationale": "记录研究的实际意义"
          }
        }
      }
    }
  }