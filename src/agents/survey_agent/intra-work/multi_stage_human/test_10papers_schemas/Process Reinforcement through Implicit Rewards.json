        "description": "研究背景和动机",
        "rationale": "理解研究问题和现有方法的局限性",
        "sub_keys": {
          "research_problem": {
            "data_type": "string",
            "description": "研究问题",
            "rationale": "明确论文关注的核心问题"
          },
          "current_limitations": {
            "data_type": "string",
            "description": "现有方法局限性",
            "rationale": "记录模仿学习和强化学习面临的挑战"
          },
          "key_challenges": {
            "data_type": "string",
            "description": "关键挑战",
            "rationale": "提取强化学习应用中的具体技术难题"
          }
        }
      },
      "core_concept": {
        "data_type": "object",
        "description": "核心思路和创新思想",
        "rationale": "记录论文的核心技术理念和灵感来源",
        "sub_keys": {
          "main_idea": {
            "data_type": "string",
            "description": "核心思想",
            "rationale": "提取隐式过程奖励建模和PRIME算法的基本理念"
          },
          "inspiration_source": {
            "data_type": "string",
            "description": "灵感来源",
            "rationale": "记录方法设计的理论基础和类比"
          }
        }
      },
      "technical_approach": {
        "data_type": "object",
        "description": "技术方案和方法细节",
        "rationale": "记录隐式过程奖励建模和强化学习算法的具体实现",
        "sub_keys": {
          "implicit_prm": {
            "data_type": "object",
            "description": "隐式过程奖励建模",
            "rationale": "提取PRM模型的技术细节和数学基础",
            "sub_keys": {
              "objective": {
                "data_type": "string",
                "description": "目标",
                "rationale": "记录PRM模型的设计目标"
              },
              "method": {
                "data_type": "string",
                "description": "方法",
                "rationale": "提取ORM模型的训练方法"
              },
              "reward_calculation": {
                "data_type": "string",
                "description": "奖励计算",
                "rationale": "记录过程奖励的具体计算公式"
              },
              "training_objective": {
                "data_type": "string",
                "description": "训练目标",
                "rationale": "提取ORM模型的训练目标函数"
              }
            }
          },
          "prime_algorithm": {
            "data_type": "object",
            "description": "PRIME强化学习算法",
            "rationale": "记录PRIME算法的流程和关键技术",
            "sub_keys": {
              "workflow": {
                "data_type": "string",
                "description": "整体流程",
                "rationale": "记录算法的主要步骤"
              },
              "key_techniques": {
                "data_type": "string",
                "description": "关键技术",
                "rationale": "提取算法中的创新技术点"
              },
              "inference_enhancement": {
                "data_type": "string",
                "description": "推理时增强",
                "rationale": "记录推理阶段的优化方法"
              }
            }
          }
        }
      },
      "experiments_and_results": {
        "data_type": "object",
        "description": "实验设置和结果分析",
        "rationale": "记录实验配置、性能评估和关键发现",
        "sub_keys": {
          "experimental_setup": {
            "data_type": "string",
            "description": "实验设置",
            "rationale": "记录使用的模型、数据集和评估指标"
          },
          "key_results": {
            "data_type": "object",
            "description": "关键结果",
            "rationale": "提取实验的主要性能发现",
            "sub_keys": {
              "algorithm_effectiveness": {
                "data_type": "string",
                "description": "算法有效性",
                "rationale": "记录PRIME算法的性能提升"
              },
              "acceleration_effect": {
                "data_type": "string",
                "description": "加速效果",
                "rationale": "提取训练速度的改进"
              },
              "online_prm_importance": {
                "data_type": "string",
                "description": "在线PRM重要性",
                "rationale": "记录在线更新的效果"
              },
              "inference_scaling_effect": {
                "data_type": "string",
                "description": "推理扩展效果",
                "rationale": "提取推理阶段优化的性能"
              }
            }
          }
        }
      },
      "conclusions": {
        "data_type": "object",
        "description": "研究结论",
        "rationale": "总结研究的主要发现和结论",
        "sub_keys": {
          "main_findings": {
            "data_type": "string",
            "description": "主要发现",
            "rationale": "记录研究的核心结论"
          }
        }
      },
      "contributions": {
        "data_type": "object",
        "description": "研究贡献",
        "rationale": "记录论文的主要创新点和价值",
        "sub_keys": {
          "technical_contributions": {
            "data_type": "string",
            "description": "技术贡献",
            "rationale": "提取方法层面的创新"
          },
          "practical_contributions": {
            "data_type": "string",
            "description": "实践贡献",
            "rationale": "记录资源效率和应用价值"
          },
          "community_contributions": {
            "data_type": "string",
            "description": "社区贡献",
            "rationale": "提取开源和后续研究影响"
          }
        }
      }
    }
  }