{
    "schema_proposal": {
      "title": {
        "data_type": "string",
        "description": "论文标题",
        "rationale": "标识论文的核心主题和研究焦点"
      },
      "motivation": {
        "data_type": "object",
        "description": "研究动机和问题背景",
        "rationale": "理解研究要解决的核心问题和观察到的现象",
        "sub_keys": {
          "problem_statement": {
            "data_type": "string",
            "description": "问题陈述",
            "rationale": "记录o1类LLM过度思考问题的具体描述"
          },
          "key_observation": {
            "data_type": "string",
            "description": "关键观察数据",
            "rationale": "提取过度思考问题的量化证据"
          },
          "research_goal": {
            "data_type": "string",
            "description": "研究目标",
            "rationale": "记录研究要达成的具体目标"
          }
        }
      },
      "overthinking_observations": {
        "data_type": "object",
        "description": "过度思考的具体观察现象",
        "rationale": "详细记录实验中发现的具体问题表现",
        "sub_keys": {
          "excessive_solution_rounds": {
            "data_type": "string",
            "description": "过多轮次解决方案现象",
            "rationale": "记录模型为简单问题生成不必要多轮解决方案"
          },
          "diminishing_accuracy_returns": {
            "data_type": "string",
            "description": "准确率回报递减现象",
            "rationale": "提取后续解决方案对准确率提升微弱的现象"
          },
          "solution_repetition": {
            "data_type": "string",
            "description": "解决方案重复现象",
            "rationale": "记录解决方案多样性不足的问题"
          }
        }
      },
      "evaluation_metrics": {
        "data_type": "object",
        "description": "提出的评估指标",
        "rationale": "记录用于量化过度思考问题的度量标准",
        "sub_keys": {
          "outcome_efficiency_metric": {
            "data_type": "string",
            "description": "结果效率指标",
            "rationale": "衡量第一个正确回答对应的token效率"
          },
          "process_efficiency_metric": {
            "data_type": "string",
            "description": "过程效率指标",
            "rationale": "衡量解决方案多样性的token效率"
          },
          "metric_application_finding": {
            "data_type": "string",
            "description": "指标应用发现",
            "rationale": "记录应用指标后的关键发现"
          }
        }
      },
      "mitigation_methods": {
        "data_type": "object",
        "description": "缓解过度思考的方法",
        "rationale": "记录提出的训练和优化方法体系",
        "sub_keys": {
          "training_approaches": {
            "data_type": "object",
            "description": "训练方法",
            "rationale": "记录各种后训练技术方法",
            "sub_keys": {
              "method_overview": {
                "data_type": "string",
                "description": "方法概述",
                "rationale": "记录训练方法的整体框架"
              },
              "specific_techniques": {
                "data_type": "string",
                "description": "具体技术",
                "rationale": "提取SFT、DPO、RPO、SimDPO等技术细节"
              },
              "training_procedure": {
                "data_type": "string",
                "description": "训练过程",
                "rationale": "记录数据生成和样本选择方法"
              },
              "method_finding": {
                "data_type": "string",
                "description": "方法发现",
                "rationale": "记录训练方法的效果观察"
              }
            }
          },
          "solution_simplification_strategies": {
            "data_type": "object",
            "description": "解决方案简化策略",
            "rationale": "记录响应简化的具体策略",
            "sub_keys": {
              "fcs_strategy": {
                "data_type": "string",
                "description": "FCS策略",
                "rationale": "记录首次正确解决方案方法"
              },
              "fcs_reflection_strategy": {
                "data_type": "string",
                "description": "FCS+反思策略",
                "rationale": "记录带反思的解决方案方法"
              },
              "gds_strategy": {
                "data_type": "string",
                "description": "GDS策略",
                "rationale": "记录贪婪多样化解决方案方法"
              }
            }
          }
        }
      },
      "experimental_results": {
        "data_type": "object",
        "description": "实验结果和分析",
        "rationale": "记录方法在各种测试集上的性能表现",
        "sub_keys": {
          "length_preference_results": {
            "data_type": "string",
            "description": "长度偏好优化结果",
            "rationale": "记录不同优化方法在减少token数量方面的表现"
          },
          "response_simplification_results": {
            "data_type": "string",
            "description": "响应简化结果",
            "rationale": "记录各种简化策略的效果和权衡"
          },
          "challenging_dataset_results": {
            "data_type": "object",
            "description": "挑战性测试集结果",
            "rationale": "记录方法在困难数据集上的泛化能力",
            "sub_keys": {
              "test_datasets": {
                "data_type": "string",
                "description": "测试数据集",
                "rationale": "记录使用的挑战性测试集信息"
              },
              "performance_results": {
                "data_type": "string",
                "description": "性能结果",
                "rationale": "提取在挑战性测试集上的具体表现"
              },
              "robustness_finding": {
                "data_type": "string",
                "description": "鲁棒性发现",
                "rationale": "记录方法的鲁棒性和泛化能力结论"
              }
            }
          }
        }
      },
      "conclusions": {
        "data_type": "object",
        "description": "研究结论和意义",
        "rationale": "总结研究的核心发现和价值",
        "sub_keys": {
          "key_contribution": {
            "data_type": "string",
            "description": "关键贡献",
            "rationale": "记录研究的主要创新点"
          },
          "efficiency_improvement": {
            "data_type": "string",
            "description": "效率提升",
            "rationale": "提取方法在减少计算资源方面的效果"
          },
          "broader_implications": {
            "data_type": "string",
            "description": "更广泛意义",
            "rationale": "记录研究对资源利用理解的贡献"
          }
        }
      }
    }
  }