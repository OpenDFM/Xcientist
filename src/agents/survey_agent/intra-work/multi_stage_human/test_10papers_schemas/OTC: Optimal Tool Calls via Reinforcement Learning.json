{
    "schema_proposal": {
      "paper_metadata": {
        "data_type": "object",
        "description": "论文基本信息",
        "rationale": "记录论文标题、作者和机构信息",
        "sub_keys": {
          "title": {
            "data_type": "string",
            "description": "论文标题",
            "rationale": "标识论文主题"
          },
          "authors": {
            "data_type": "list",
            "description": "作者列表",
            "rationale": "记录论文贡献者"
          },
          "affiliations": {
            "data_type": "list",
            "description": "所属机构",
            "rationale": "记录作者所属单位"
          }
        }
      },
      "problem_background": {
        "data_type": "object",
        "description": "问题背景和挑战",
        "rationale": "理解研究动机和核心问题",
        "sub_keys": {
          "current_issues": {
            "data_type": "string",
            "description": "现有方法存在的问题",
            "rationale": "记录现有强化学习方法在工具调用效率方面的不足"
          },
          "target": {
            "data_type": "string",
            "description": "目标描述",
            "rationale": "提取研究要解决的关键技术以及要达成的目标"
          }
        }
      },
      "contributions": {
        "data_type": "object",
        "description": "主要贡献",
        "rationale": "记录论文的核心创新点和价值",
        "sub_keys": {
          "framework_innovation": {
            "data_type": "string",
            "description": "框架创新",
            "rationale": "提取方法层面的创新"
          },
          "metric_innovation": {
            "data_type": "string",
            "description": "指标创新",
            "rationale": "记录新提出的评估指标"
          },
          "algorithm_innovation": {
            "data_type": "string",
            "description": "算法创新",
            "rationale": "提取算法设计的创新点"
          },
          "performance_improvement": {
            "data_type": "string",
            "description": "性能提升",
            "rationale": "记录方法带来的实际改进"
          }
        }
      },
      "key_findings": {
        "data_type": "object",
        "description": "关键发现和结论",
        "rationale": "提取实验验证的核心结论",
        "sub_keys": {
          "tool_call_reduction": {
            "data_type": "string",
            "description": "工具调用减少效果",
            "rationale": "记录工具调用次数的优化结果"
          },
          "model_size_effect": {
            "data_type": "string",
            "description": "模型规模影响",
            "rationale": "提取模型规模对方法效果的影响"
          },
          "generalization_performance": {
            "data_type": "string",
            "description": "泛化性能",
            "rationale": "记录方法在未见数据上的表现"
          },
          "case_study_insights": {
            "data_type": "string",
            "description": "案例分析洞察",
            "rationale": "提取具体案例对比的发现"
          }
        }
      },
      "methodology": {
        "data_type": "object",
        "description": "方法细节",
        "rationale": "记录技术实现的具体方案",
        "sub_keys": {
          "task_definition": {
            "data_type": "string",
            "description": "任务定义",
            "rationale": "提取问题形式化描述"
          },
          "reward_function": {
            "data_type": "object",
            "description": "奖励函数设计",
            "rationale": "记录强化学习奖励机制",
            "sub_keys": {
              "base_reward": {
                "data_type": "string",
                "description": "基础奖励",
                "rationale": "记录答案正确性奖励"
              },
              "efficiency_reward": {
                "data_type": "string",
                "description": "效率奖励",
                "rationale": "提取工具使用效率奖励设计"
              },
              "final_reward": {
                "data_type": "string",
                "description": "最终奖励",
                "rationale": "记录奖励组合方式"
              }
            }
          },
          "algorithm_integration": {
            "data_type": "string",
            "description": "算法集成",
            "rationale": "记录与PPO/GRPO的结合方式"
          }
        }
      },
      "experiments": {
        "data_type": "object",
        "description": "实验设置和结果",
        "rationale": "提取实验配置和性能评估",
        "sub_keys": {
          "experimental_setup": {
            "data_type": "object",
            "description": "实验设置",
            "rationale": "记录实验环境和参数配置",
            "sub_keys": {
              "datasets": {
                "data_type": "string",
                "description": "数据集信息",
                "rationale": "记录使用的数据集"
              },
              "models": {
                "data_type": "string",
                "description": "模型信息",
                "rationale": "提取使用的模型规格"
              },
              "parameters": {
                "data_type": "string",
                "description": "参数配置",
                "rationale": "记录超参数设置"
              },
              "resources": {
                "data_type": "string",
                "description": "训练资源",
                "rationale": "记录计算资源信息"
              }
            }
          },
          "experimental_results": {
            "data_type": "object",
            "description": "实验结果",
            "rationale": "提取定量和定性评估结果",
            "sub_keys": {
              "search_tool_results": {
                "data_type": "string",
                "description": "搜索工具效果",
                "rationale": "记录搜索任务上的性能"
              },
              "code_tool_results": {
                "data_type": "string",
                "description": "代码工具效果",
                "rationale": "记录代码任务上的性能"
              },
              "behavior_analysis": {
                "data_type": "string",
                "description": "行为分析",
                "rationale": "提取模型行为模式分析"
              }
            }
          }
        }
      }
    }
  }